# Copy this to .dev.vars for local `wrangler dev` / `wrangler pages dev`
# These mirror the secrets you set in Cloudflare dashboard via `wrangler secret put`
GOOGLE_SERVICE_ACCOUNT_EMAIL=my-service-account@my-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-spreadsheet-id-from-the-url

# Supabase — find in: Supabase Dashboard > Project Settings > API
# VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY are already set in wrangler.jsonc vars section
# Add the service role key ONLY in .dev.vars / Cloudflare secret — never commit or expose client-side
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Your public site URL — used to build the password reset redirect link
# For local dev, use: http://localhost:5173
# For production, use: https://chessparfait.com (or your actual domain)
SITE_URL=http://localhost:5173
